@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="mb-0">
                        <i class="fas fa-sign-in-alt"></i> Welcome Back
                    </h3>
                    <p class="mb-0">Sign in to your account</p>
                </div>

                <div class="card-body p-5">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form action="@Url.Action("Login", "Account")" method="post">
                        @Html.Hidden("returnUrl", ViewBag.ReturnUrl as string)

                        <div class="mb-4">
                            <label class="form-label">
                                <i class="fas fa-user"></i> Username
                            </label>
                            <input type="text" name="username" class="form-control form-control-lg"
                                   placeholder="Enter your username" required autofocus />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">
                                <i class="fas fa-lock"></i> Password
                            </label>
                            <div class="input-group">
                                <input type="password" name="password" id="passwordField" class="form-control form-control-lg"
                                       placeholder="Enter your password" required />
                                <button type="button" class="btn btn-outline-secondary" id="togglePassword">
                                    <i class="fas fa-eye" id="eyeIcon"></i>
                                </button>
                            </div>
                        </div>

                        <div class="d-grid mb-4">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-sign-in-alt"></i> Sign In
                            </button>
                        </div>
                    </form>

                    <div class="text-center">
                        <p class="mb-0">Don't have an account?</p>
                        @Html.ActionLink("Create New Account", "Register", "Account", null, new { @class = "btn btn-outline-primary" })
                    </div>
                </div>

                @*<div class="card-footer bg-light text-center py-3">
                    <small class="text-muted">
                        Demo Accounts: <br>
                        Admin: <strong>admin</strong> / <strong>admin123</strong><br>
                        User: <strong>testuser</strong> / <strong>user123</strong><br><br>
                        <a href="@Url.Action("CreateTestUsers", "Account")" class="btn btn-sm btn-outline-secondary me-2">
                            Create Test Users
                        </a>
                        <a href="@Url.Action("ClearSession", "Account")" class="btn btn-sm btn-outline-warning">
                            Clear Session
                        </a>
                    </small>
                </div>*@
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('togglePassword').addEventListener('click', function () {
        const passwordField = document.getElementById('passwordField');
        const eyeIcon = document.getElementById('eyeIcon');

        if (passwordField.type === 'password') {
            passwordField.type = 'text';
            eyeIcon.className = 'fas fa-eye-slash';
        } else {
            passwordField.type = 'password';
            eyeIcon.className = 'fas fa-eye';
        }
    });
</script>