@{
    ViewBag.Title = "Browse Events";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>🔍 Browse Events</h2>
    <p class="lead">Discover exciting events happening around you</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="row">
        @if (ViewBag.Events != null && ((System.Collections.IList)ViewBag.Events).Count > 0)
        {
            foreach (var eventItem in ViewBag.Events)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card event-card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@eventItem.Title</h5>
                            <p class="card-text">@eventItem.Description</p>
                            <p class="text-muted">
                                <i class="fas fa-calendar"></i> @eventItem.EventDate.ToString("MMM dd, yyyy")<br>
                                <i class="fas fa-clock"></i> @eventItem.StartTime.ToString(@"hh\:mm")<br>
                                <i class="fas fa-users"></i> Max: @eventItem.MaxParticipants participants<br>
                                <i class="fas fa-rupee-sign"></i> @(eventItem.IsFree ? "Free" : "₹" + eventItem.Price.ToString("0.00"))
                            </p>
                        </div>
                        <div class="card-footer">
                            <form method="post" action="@Url.Action("RegisterForEvent", "User")">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="eventId" value="@eventItem.EventId" />
                                <button type="submit" class="btn btn-primary w-100" onclick="return confirm('Register for this event?')">
                                    Register Now
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <h4>No Events Available</h4>
                    <p>There are currently no events available for registration.</p>
                    @if (ViewBag.TotalEventsInDB != null)
                    {
                        <div class="text-muted small">
                            <strong>Debug Info:</strong><br>
                            Total events in database: @ViewBag.TotalEventsInDB<br>
                            Filtered events: @(ViewBag.FilteredCount ?? 0)<br>
                            Current date: @ViewBag.CurrentDate<br>
                            @if (ViewBag.FirstEventDate != null)
                            {
                                <text>First event date: @ViewBag.FirstEventDate<br></text>
                                <text>First event active: @ViewBag.FirstEventActive<br></text>
                                <text>First event public: @ViewBag.FirstEventPublic</text>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Dashboard", "User")" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>