@{
    ViewBag.Title = "My Events";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>📅 My Events</h2>
    <p class="lead">Events you have registered for</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="row">
        @if (ViewBag.MyEvents != null && ((System.Collections.IList)ViewBag.MyEvents).Count > 0)
        {
            foreach (var eventItem in ViewBag.MyEvents)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card event-card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@eventItem.Title</h5>
                            <p class="card-text">@eventItem.Description</p>
                            <p class="text-muted">
                                <i class="fas fa-calendar"></i> @eventItem.EventDate.ToString("MMM dd, yyyy")<br>
                                <i class="fas fa-clock"></i> @eventItem.StartTime.ToString(@"hh\:mm")<br>
                                <i class="fas fa-users"></i> Max: @eventItem.MaxParticipants participants<br>
                                <i class="fas fa-rupee-sign"></i> @(eventItem.IsFree ? "Free" : "₹" + eventItem.Price.ToString("0.00"))
                            </p>
                            @if (eventItem.EventDate >= DateTime.Today)
                            {
                                <span class="badge bg-success">Upcoming</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Completed</span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <h4>No Events Registered</h4>
                    <p>You haven't registered for any events yet.</p>
                    <a href="@Url.Action("BrowseEvents", "User")" class="btn btn-primary">Browse Events</a>
                </div>
            </div>
        }
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Dashboard", "User")" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>