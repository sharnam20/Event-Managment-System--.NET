@{
    ViewBag.Title = "Upcoming Events";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>⏰ Upcoming Events</h2>
    <p class="lead">Events you're registered for that are coming up</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <div class="row">
        @if (ViewBag.UpcomingEvents != null && ((System.Collections.IList)ViewBag.UpcomingEvents).Count > 0)
        {
            foreach (var eventItem in ViewBag.UpcomingEvents)
            {
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card event-card h-100 border-primary">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@eventItem.Title</h5>
                            <p class="card-text">@eventItem.Description</p>
                            <p class="text-muted">
                                <i class="fas fa-calendar text-primary"></i> @eventItem.EventDate.ToString("MMM dd, yyyy")<br>
                                <i class="fas fa-clock text-primary"></i> @eventItem.StartTime.ToString(@"hh\:mm")<br>
                                <i class="fas fa-users"></i> Max: @eventItem.MaxParticipants participants<br>
                                <i class="fas fa-rupee-sign"></i> @(eventItem.IsFree ? "Free" : "₹" + eventItem.Price.ToString("0.00"))
                            </p>
                            <span class="badge bg-primary">Upcoming</span>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center">
                    <h4>No Upcoming Events</h4>
                    <p>You don't have any upcoming events.</p>
                    <a href="@Url.Action("BrowseEvents", "User")" class="btn btn-primary">Browse Events</a>
                </div>
            </div>
        }
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Dashboard", "User")" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>