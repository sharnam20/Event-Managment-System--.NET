@{
    ViewBag.Title = "EventHub - Your Premier Event Management Platform";
}

<style>
    body {
        margin: 0;
        padding: 0;
    }

    .hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 70vh;
        display: flex;
        align-items: center;
        color: white;
        position: relative;
        overflow: hidden;
    }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="20" cy="20" r="2" fill="rgba(255,255,255,0.1)"/><circle cx="80" cy="80" r="2" fill="rgba(255,255,255,0.1)"/><circle cx="40" cy="60" r="1" fill="rgba(255,255,255,0.1)"/></svg>');
            animation: float 20s ease-in-out infinite;
        }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-20px);
        }
    }

    .hero-content {
        position: relative;
        z-index: 2;
    }

    .hero h1 {
        font-size: 4rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .hero p {
        font-size: 1.4rem;
        margin-bottom: 2rem;
        opacity: 0.9;
    }

    .btn-hero {
        padding: 15px 40px;
        font-size: 1.1rem;
        font-weight: 600;
        border-radius: 50px;
        text-decoration: none;
        display: inline-block;
        margin: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    }

        .btn-hero:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 35px rgba(0,0,0,0.3);
        }

    .btn-light-hero {
        background: white;
        color: #667eea;
    }

    .btn-outline-hero {
        background: transparent;
        color: white;
        border: 2px solid white;
    }

    .features {
        padding: 60px 0;
        background: #f8f9fa;
    }

    .feature-box {
        background: white;
        padding: 50px 30px;
        border-radius: 20px;
        text-align: center;
        box-shadow: 0 15px 50px rgba(0,0,0,0.1);
        transition: all 0.3s ease;
        margin-bottom: 30px;
        height: 100%;
    }

        .feature-box:hover {
            transform: translateY(-10px);
            box-shadow: 0 25px 60px rgba(0,0,0,0.15);
        }

    .feature-icon {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 30px;
        font-size: 2.5rem;
        color: white;
    }

    .icon-blue {
        background: linear-gradient(135deg, #667eea, #764ba2);
    }

    .icon-green {
        background: linear-gradient(135deg, #11998e, #38ef7d);
    }

    .icon-orange {
        background: linear-gradient(135deg, #f093fb, #f5576c);
    }

    .stats {
        padding: 60px 0;
        background: white;
    }

    .stat-box {
        text-align: center;
        padding: 40px 20px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 15px 50px rgba(0,0,0,0.08);
        margin-bottom: 30px;
        transition: all 0.3s ease;
    }

        .stat-box:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.12);
        }

    .stat-number {
        font-size: 4rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .cta {
        padding: 60px 0;
        background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
        color: white;
        text-align: center;
    }

    .section-title {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 20px;
        text-align: center;
    }

    .section-subtitle {
        font-size: 1.2rem;
        color: #666;
        margin-bottom: 60px;
        text-align: center;
    }

    @@media (max-width: 768px) {
        .hero h1 {
            font-size: 2.5rem;
        }

        .hero p {
            font-size: 1.1rem;
        }

        .section-title {
            font-size: 2rem;
        }
    }
</style>

<!-- Hero Section -->
<section class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 hero-content">
                <h1>Welcome to EventHub</h1>
                <p>Discover amazing events, connect with people, and create unforgettable experiences. Your gateway to the best events in town!</p>
                <div>
                    @if (!User.Identity.IsAuthenticated)
                    {
                        @Html.ActionLink("Get Started", "Register", "Account", null, new { @class = "btn-hero btn-light-hero" })
                        @Html.ActionLink("Sign In", "Login", "Account", null, new { @class = "btn-hero btn-outline-hero" })
                    }
                    else
                    {
                        @Html.ActionLink("Browse Events", "BrowseEvents", "User", null, new { @class = "btn-hero btn-light-hero" })
                    }
                </div>
            </div>
            <div class="col-lg-6 text-center">
                <i class="fas fa-calendar-alt" style="font-size: 15rem; opacity: 0.2;"></i>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="features">
    <div class="container">
        <h2 class="section-title">Why Choose EventHub?</h2>
        <p class="section-subtitle">Everything you need for amazing events</p>

        <div class="row">
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-icon icon-blue">
                        <i class="fas fa-search"></i>
                    </div>
                    <h4 style="font-weight: 600; margin-bottom: 20px;">Discover Events</h4>
                    <p style="color: #666; line-height: 1.6;">Find events that match your interests with our powerful search and filtering system.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-icon icon-green">
                        <i class="fas fa-ticket-alt"></i>
                    </div>
                    <h4 style="font-weight: 600; margin-bottom: 20px;">Easy Registration</h4>
                    <p style="color: #666; line-height: 1.6;">Register for events with just a few clicks and get your digital tickets instantly.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-box">
                    <div class="feature-icon icon-orange">
                        <i class="fas fa-qrcode"></i>
                    </div>
                    <h4 style="font-weight: 600; margin-bottom: 20px;">QR Code Tickets</h4>
                    <p style="color: #666; line-height: 1.6;">Get QR code tickets for easy check-in and a seamless event experience.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="stats">
    <div class="container">
        <div class="row">
            <div class="col-md-4">
                <div class="stat-box">
                    <i class="fas fa-calendar-check" style="font-size: 3rem; color: #667eea; margin-bottom: 20px;"></i>
                    <div class="stat-number" style="color: #667eea;">500+</div>
                    <p style="color: #666; font-size: 1.1rem; margin: 0;">Events Hosted</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-box">
                    <i class="fas fa-users" style="font-size: 3rem; color: #11998e; margin-bottom: 20px;"></i>
                    <div class="stat-number" style="color: #11998e;">10K+</div>
                    <p style="color: #666; font-size: 1.1rem; margin: 0;">Happy Users</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-box">
                    <i class="fas fa-star" style="font-size: 3rem; color: #f5576c; margin-bottom: 20px;"></i>
                    <div class="stat-number" style="color: #f5576c;">4.9</div>
                    <p style="color: #666; font-size: 1.1rem; margin: 0;">Events Hosted</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
@if (!User.Identity.IsAuthenticated)
{
    <section class="cta">
        <div class="container">
            <h2 style="font-size: 3rem; font-weight: 700; margin-bottom: 20px;">Ready to Get Started?</h2>
            <p style="font-size: 1.3rem; margin-bottom: 40px; opacity: 0.9;">Join thousands of event organizers and attendees on EventHub</p>
            <div>
                @Html.ActionLink("Create Account", "Register", "Account", null, new { @class = "btn-hero btn-light-hero" })
                @Html.ActionLink("Sign In", "Login", "Account", null, new { @class = "btn-hero btn-outline-hero" })
            </div>
        </div>
    </section>
}