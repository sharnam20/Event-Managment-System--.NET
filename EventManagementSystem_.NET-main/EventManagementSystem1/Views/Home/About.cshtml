@{
    ViewBag.Title = "About Us - EventHub";
}

<!-- Page Header -->
<section class="page-header" style="background: linear-gradient(135deg, #2c3e50, #3498db); color: white; padding: 80px 0; text-align: center;">
    <div class="container">
        <h1 class="display-4 fw-bold">About EventHub</h1>
        <p class="lead">Meet the team behind your favorite event management platform</p>
    </div>
</section>

<div class="container py-5">
    <!-- Mission Section -->
    <div class="row mb-5">
        <div class="col-lg-8 mx-auto text-center">
            <h2 class="mb-4">Our Mission</h2>
            <p class="lead text-muted">
                EventHub was created to simplify event management and bring communities together.
                We believe that great events create lasting memories and meaningful connections.
            </p>
        </div>
    </div>

    <!-- Team Section -->
    <div class="row mb-5">
        <div class="col-12 text-center mb-5">
            <h2 class="display-5 fw-bold">Meet Our Team</h2>
            <p class="lead text-muted">The passionate developers behind EventHub</p>
        </div>
    </div>

    <div class="row justify-content-center">
        <!-- OM PATEL -->
        <div class="col-lg-5 col-md-6 mb-4">
            <div class="card border-0 shadow-lg h-100">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <div class="rounded-circle bg-primary d-inline-flex align-items-center justify-content-center"
                             style="width: 120px; height: 120px; font-size: 3rem; color: white;">
                            OP
                        </div>
                    </div>
                    <h4 class="fw-bold mb-2">OM PATEL</h4>
                    <p class="text-primary mb-3">Co-Founder & Lead Developer</p>
                    <p class="text-muted mb-4">
                        Passionate full-stack developer with expertise in ASP.NET MVC, C#, and modern web technologies.
                        OM specializes in creating robust backend systems and user-friendly interfaces.
                    </p>
                    <div class="mb-3">
                        <h6 class="fw-bold">Specializations:</h6>
                        <div class="d-flex flex-wrap justify-content-center gap-2">
                            <span class="badge bg-primary">ASP.NET MVC</span>
                            <span class="badge bg-secondary">C#</span>
                            <span class="badge bg-success">SQL Server</span>
                            <span class="badge bg-info">Entity Framework</span>
                        </div>
                    </div>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="#" class="text-primary"><i class="fab fa-linkedin fa-lg"></i></a>
                        <a href="#" class="text-dark"><i class="fab fa-github fa-lg"></i></a>
                        <a href="#" class="text-info"><i class="fab fa-twitter fa-lg"></i></a>
                    </div>
                </div>
            </div>
        </div>

        <!-- SHARNAM SHAH -->
        <div class="col-lg-5 col-md-6 mb-4">
            <div class="card border-0 shadow-lg h-100">
                <div class="card-body text-center p-5">
                    <div class="mb-4">
                        <div class="rounded-circle bg-success d-inline-flex align-items-center justify-content-center"
                             style="width: 120px; height: 120px; font-size: 3rem; color: white;">
                            SS
                        </div>
                    </div>
                    <h4 class="fw-bold mb-2">SHARNAM SHAH</h4>
                    <p class="text-success mb-3">Co-Founder & Frontend Architect</p>
                    <p class="text-muted mb-4">
                        Creative frontend developer with a keen eye for design and user experience.
                        SHARNAM focuses on creating beautiful, responsive interfaces and seamless user interactions.
                    </p>
                    <div class="mb-3">
                        <h6 class="fw-bold">Specializations:</h6>
                        <div class="d-flex flex-wrap justify-content-center gap-2">
                            <span class="badge bg-warning">JavaScript</span>
                            <span class="badge bg-primary">Bootstrap</span>
                            <span class="badge bg-danger">HTML/CSS</span>
                            <span class="badge bg-info">UI/UX Design</span>
                        </div>
                    </div>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="#" class="text-primary"><i class="fab fa-linkedin fa-lg"></i></a>
                        <a href="#" class="text-dark"><i class="fab fa-github fa-lg"></i></a>
                        <a href="#" class="text-info"><i class="fab fa-twitter fa-lg"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Technology Stack -->
    <div class="row mt-5">
        <div class="col-12 text-center mb-4">
            <h3 class="fw-bold">Built With Modern Technology</h3>
            <p class="text-muted">EventHub is powered by cutting-edge technologies</p>
        </div>
    </div>

    <div class="row text-center">
        <div class="col-md-3 mb-3">
            <div class="p-3">
                <i class="fab fa-microsoft text-primary" style="font-size: 3rem;"></i>
                <h6 class="mt-2">ASP.NET MVC</h6>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="p-3">
                <i class="fas fa-database text-success" style="font-size: 3rem;"></i>
                <h6 class="mt-2">SQL Server</h6>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="p-3">
                <i class="fab fa-bootstrap text-primary" style="font-size: 3rem;"></i>
                <h6 class="mt-2">Bootstrap 5</h6>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="p-3">
                <i class="fab fa-js-square text-warning" style="font-size: 3rem;"></i>
                <h6 class="mt-2">JavaScript</h6>
            </div>
        </div>
    </div>

    <!-- Contact Section -->
    <div class="row mt-5">
        <div class="col-lg-8 mx-auto">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5 text-center">
                    <h3 class="fw-bold mb-3">Get In Touch</h3>
                    <p class="text-muted mb-4">
                        Have questions about EventHub or want to collaborate? We'd love to hear from you!
                    </p>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center justify-content-center">
                                <i class="fas fa-envelope text-primary me-3"></i>
                                <span>contact@eventhub.com</span>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex align-items-center justify-content-center">
                                <i class="fas fa-phone text-success me-3"></i>
                                <span>+91 98765 43210</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>