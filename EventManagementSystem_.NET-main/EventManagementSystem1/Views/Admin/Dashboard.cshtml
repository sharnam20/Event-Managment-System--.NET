@{
    ViewBag.Title = "Admin Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="container">
        <h1>📊 Admin Dashboard</h1>
        <p class="lead">Manage your events and monitor system performance</p>
    </div>
</div>

<div class="container">
    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card stats-card text-center">
                <div class="card-body">
                    <div style="font-size: 3rem;">📅</div>
                    <h3>@ViewBag.TotalEvents</h3>
                    <p class="mb-0">Total Events</p>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card stats-card text-center">
                <div class="card-body">
                    <div style="font-size: 3rem;">👥</div>
                    <h3>@ViewBag.TotalUsers</h3>
                    <p class="mb-0">Registered Users</p>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card stats-card text-center">
                <div class="card-body">
                    <div style="font-size: 3rem;">✅</div>
                    <h3>@ViewBag.TotalParticipants</h3>
                    <p class="mb-0">Total Registrations</p>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card stats-card text-center">
                <div class="card-body">
                    <div style="font-size: 3rem;">📍</div>
                    <h3>@ViewBag.TotalVenues</h3>
                    <p class="mb-0">Active Venues</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">⚡ Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-lg-3 col-md-6 mb-3">
                            <a href="@Url.Action("CreateEvent", "Admin")" class="btn btn-primary btn-lg w-100">Create Event</a>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-3">
                            <a href="@Url.Action("ManageEvents", "Admin")" class="btn btn-secondary btn-lg w-100">Manage Events</a>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-3">
                            <a href="@Url.Action("AddVenue", "Admin")" class="btn btn-success btn-lg w-100">Add Venue</a>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-3">
                            <a href="@Url.Action("AddCategory", "Admin")" class="btn btn-info btn-lg w-100">Add Category</a>
                        </div>
                    </div>
                    <div class="row mt-3">
                        <div class="col-lg-3 col-md-6 mb-3">
                            <a href="@Url.Action("ManageUsers", "Admin")" class="btn btn-purple btn-lg w-100" style="background: #6f42c1; color: white;">Manage Users</a>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-3">
                            <a href="@Url.Action("ManageParticipants", "Admin")" class="btn btn-dark btn-lg w-100">Manage Participants</a>
                        </div>
                        <div class="col-lg-3 col-md-6 mb-3">
                            <a href="@Url.Action("Reports", "Admin")" class="btn btn-warning btn-lg w-100">View Reports</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>