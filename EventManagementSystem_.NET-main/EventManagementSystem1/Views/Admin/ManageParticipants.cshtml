@{
    ViewBag.Title = "Manage Participants";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <h2>👥 Manage Participants</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card">
        <div class="card-body">
            @if (ViewBag.Participants != null && ((System.Collections.IList)ViewBag.Participants).Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Participant Name</th>
                                <th>Event Title</th>
                                <th>Registration Date</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var participant in ViewBag.Participants)
                            {
                                var user = ((List<EventManagementSystem1.Models.User>)ViewBag.Users).FirstOrDefault(u => u.UserId == participant.UserId);
                                var eventItem = ((List<EventManagementSystem1.Models.Event>)ViewBag.Events).FirstOrDefault(e => e.EventId == participant.EventId);
                                <tr>
                                    <td>@(user != null ? user.FullName : "Unknown User")</td>
                                    <td>@(eventItem != null ? eventItem.Title : "Unknown Event")</td>
                                    <td>@participant.RegistrationDate.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (participant.AttendanceStatus == "Registered")
                                        {
                                            <span class="badge bg-success">@participant.AttendanceStatus</span>
                                        }
                                        else if (participant.AttendanceStatus == "Attended")
                                        {
                                            <span class="badge bg-primary">@participant.AttendanceStatus</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@participant.AttendanceStatus</span>
                                        }
                                    </td>
                                    <td>
                                        <form method="post" action="@Url.Action("DeleteParticipant", "Admin")" style="display:inline;"
                                              onsubmit="return confirm('Are you sure you want to remove this participant?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@participant.ParticipantId" />
                                            <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted">No participants found.</p>
            }
        </div>
    </div>

    <div class="mt-3">
        <a href="@Url.Action("Dashboard", "Admin")" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>