@{
    ViewBag.Title = "Edit User";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0">✏️ Edit User</h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    @if (ViewBag.User != null)
                    {
                        <form method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@ViewBag.User.UserId" />

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Username</label>
                                    <input type="text" name="username" class="form-control" value="@ViewBag.User.Username" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Role</label>
                                    <select name="role" class="form-control" required>
                                        <option value="User" @(ViewBag.User.Role == "User" ? "selected" : "")>User</option>
                                        <option value="Admin" @(ViewBag.User.Role == "Admin" ? "selected" : "")>Admin</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">First Name</label>
                                    <input type="text" name="firstName" class="form-control" value="@ViewBag.User.FirstName" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Last Name</label>
                                    <input type="text" name="lastName" class="form-control" value="@ViewBag.User.LastName" required />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="email" class="form-control" value="@ViewBag.User.Email" required />
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Phone Number</label>
                                    <input type="tel" name="phoneNumber" class="form-control" value="@ViewBag.User.PhoneNumber" />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Status</label>
                                    <select name="isActive" class="form-control" required>
                                        <option value="true" @(ViewBag.User.IsActive ? "selected" : "")>Active</option>
                                        <option value="false" @(!ViewBag.User.IsActive ? "selected" : "")>Inactive</option>
                                    </select>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between">
                                <a href="@Url.Action("ManageUsers", "Admin")" class="btn btn-secondary">Cancel</a>
                                <button type="submit" class="btn btn-warning">Update User</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <p class="text-danger">User not found.</p>
                        <a href="@Url.Action("ManageUsers", "Admin")" class="btn btn-secondary">Back to Users</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>