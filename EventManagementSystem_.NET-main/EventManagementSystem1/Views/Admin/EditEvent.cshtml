@{
    ViewBag.Title = "Edit Event";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="card">
                <div class="card-header bg-warning text-white">
                    <h4 class="mb-0">✏️ Edit Event</h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    @if (ViewBag.Event != null)
                    {
                        <form method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@ViewBag.Event.EventId" />

                            <div class="mb-3">
                                <label class="form-label">Event Title</label>
                                <input type="text" name="title" class="form-control" value="@ViewBag.Event.Title" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea name="description" class="form-control" rows="4">@ViewBag.Event.Description</textarea>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Category</label>
                                    <select name="categoryId" class="form-control" required>
                                        <option value="">Select Category</option>
                                        @if (ViewBag.Categories != null)
                                        {
                                            foreach (var category in ViewBag.Categories)
                                            {
                                                <option value="@category.CategoryId" @(ViewBag.Event.CategoryId == category.CategoryId ? "selected" : "")>@category.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Venue</label>
                                    <select name="venueId" class="form-control" required>
                                        <option value="">Select Venue</option>
                                        @if (ViewBag.Venues != null)
                                        {
                                            foreach (var venue in ViewBag.Venues)
                                            {
                                                <option value="@venue.VenueId" @(ViewBag.Event.VenueId == venue.VenueId ? "selected" : "")>@venue.Name</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Event Date</label>
                                    <input type="date" name="eventDate" class="form-control" value="@ViewBag.Event.EventDate.ToString("yyyy-MM-dd")" required />
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Start Time</label>
                                    <input type="time" name="startTime" class="form-control" value="@ViewBag.Event.StartTime.ToString(@"hh\:mm")" required />
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Max Participants</label>
                                    <input type="number" name="maxParticipants" class="form-control" min="1" value="@ViewBag.Event.MaxParticipants" required />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Price (₹)</label>
                                    <input type="number" name="price" class="form-control" min="0" step="0.01" value="@ViewBag.Event.Price" />
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label">Status</label>
                                    <select name="isActive" class="form-control" required>
                                        <option value="true" @(ViewBag.Event.IsActive ? "selected" : "")>Active</option>
                                        <option value="false" @(!ViewBag.Event.IsActive ? "selected" : "")>Inactive</option>
                                    </select>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between">
                                <a href="@Url.Action("ManageEvents", "Admin")" class="btn btn-secondary">Cancel</a>
                                <button type="submit" class="btn btn-warning">Update Event</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <p class="text-danger">Event not found.</p>
                        <a href="@Url.Action("ManageEvents", "Admin")" class="btn btn-secondary">Back to Events</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>